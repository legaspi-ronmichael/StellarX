# Server
PORT=5000
NODE_ENV=development

# Database
MONGODB_URI=mongodb://localhost:27017/stellar-league

# Auth
JWT_SECRET=replace_with_a_long_random_string_min_32_chars
JWT_EXPIRES_IN=7d

# Stellar - Testnet
STELLAR_NETWORK=TESTNET
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015
STELLAR_FRIENDBOT_URL=https://friendbot.stellar.org

# Treasury signer keys (TESTNET ONLY - for production use hardware wallets)
# These are the 3 signer secret keys for the multi-sig treasury
# Generated by seed.js on first run if not set
TREASURY_SIGNER_1_SECRET=
TREASURY_SIGNER_2_SECRET=
TREASURY_SIGNER_3_SECRET=

# CORS
CORS_ORIGIN=http://localhost:5173
